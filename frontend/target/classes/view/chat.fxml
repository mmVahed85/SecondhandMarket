<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="792.0" prefWidth="1328.0" nodeOrientation="RIGHT_TO_LEFT" style="-fx-background-color: #e5ddd5;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.controller.ChatController">

    <!-- هدر (نوار بالای چت) -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" style="-fx-background-color: #ededed; -fx-border-color: #ccc; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets left="30.0" right="30.0" />
            </padding>
            <children>
                <Button mnemonicParsing="false" onAction="#goBack" prefHeight="40.0" prefWidth="90.0" style="-fx-background-color: white; -fx-border-color: #2196F3; -fx-text-fill: #2196F3; -fx-border-radius: 5;" text="بازگشت">
                    <font><Font name="B Yekan" size="14.0" /></font>
                </Button>

                <VBox alignment="CENTER_LEFT" spacing="5.0">
                    <children>
                        <Label fx:id="chatPartnerNameLabel" text="نام مخاطب">
                            <font><Font name="B Yekan" size="18.0" /></font>
                        </Label>
                        <Label fx:id="adTitleLabel" text="درباره آگهی..." textFill="#757575">
                            <font><Font name="B Yekan" size="12.0" /></font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>
    </top>

    <!-- محیط نمایش پیام‌ها -->
    <center>
        <ScrollPane fx:id="chatScrollPane" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox fx:id="messagesContainer" spacing="15.0">
                    <padding>
                        <Insets bottom="20.0" left="50.0" right="50.0" top="20.0" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <!-- نوار ارسال پیام در پایین -->
    <bottom>
        <HBox alignment="CENTER" prefHeight="80.0" spacing="15.0" style="-fx-background-color: #f0f0f0; -fx-border-color: #ccc; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets left="50.0" right="50.0" />
            </padding>
            <children>

                <!-- دکمه ارسال (چون صفحه راست‌چین است، اولین آیتم در سمت راست قرار می‌گیرد) -->
                <Button mnemonicParsing="false" onAction="#handleSendMessage" prefHeight="45.0" prefWidth="100.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 20;" text="ارسال">
                    <font><Font name="B Yekan" size="16.0" /></font>
                </Button>

                <!-- کادر تایپ پیام (در سمت چپ قرار می‌گیرد و متن آن چپ‌چین می‌شود) -->
                <TextField fx:id="messageInputField" nodeOrientation="LEFT_TO_RIGHT" onAction="#handleSendMessage" prefHeight="45.0" promptText="Type your message..." style="-fx-background-radius: 20;" HBox.hgrow="ALWAYS">
                    <font><Font name="Arial" size="16.0" /></font>
                </TextField>

            </children>
        </HBox>
    </bottom>

</BorderPane>