<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="792.0" prefWidth="1328.0" nodeOrientation="RIGHT_TO_LEFT" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.controller.AdminPanelController">

    <!-- سایدبار -->
    <left>
        <VBox prefWidth="250.0" spacing="20.0" style="-fx-background-color: #2c3e50;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="20.0" right="20.0" top="40.0" />
            </padding>
            <children>
                <Label text="پنل مدیریت" textFill="WHITE">
                    <font>
                        <Font name="B Yekan" size="24.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </Label>

                <Separator opacity="0.3" prefWidth="200.0" />

                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showAdsManager" prefHeight="45.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: #34495e; -fx-border-radius: 5;" text="مدیریت آگهی‌ها">
                    <font>
                        <Font name="B Yekan" size="16.0" />
                    </font>
                </Button>

                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showUsersManager" prefHeight="45.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: #34495e; -fx-border-radius: 5;" text="مدیریت کاربران">
                    <font>
                        <Font name="B Yekan" size="16.0" />
                    </font>
                </Button>

                <VBox VBox.vgrow="ALWAYS" />

                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#goBack" prefHeight="45.0" style="-fx-background-color: #bde8f8ff; -fx-text-fill: white;" text="بازگشت">
                    <font><Font name="B Yekan" size="16.0" /></font>
                </Button>

                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogout" prefHeight="45.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="خروج از سیستم">
                    <font>
                        <Font name="B Yekan" size="16.0" />
                    </font>
                </Button>
            </children>
        </VBox>
    </left>

    <!-- محتوای اصلی -->
    <center>
        <VBox spacing="20.0" style="-fx-background-color: #f5f6fa;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            <children>

                <!-- هدر و فیلتر وضعیت (بخش جدید) -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label fx:id="sectionTitleLabel" text="مدیریت آگهی‌ها" textFill="#2c3e50">
                            <font>
                                <Font name="B Yekan" size="28.0" />
                            </font>
                        </Label>

                        <!-- فیلتر وضعیت آگهی -->
                        <ComboBox fx:id="statusFilterComboBox" onAction="#handleFilterAds" prefHeight="40.0" prefWidth="150.0" promptText="همه وضعیت‌ها" style="-fx-font-family: 'B Yekan'; -fx-font-size: 14px;"/>
                    </children>
                </HBox>

                <!-- پیام‌های سیستم -->
                <Label fx:id="messageLabel" textFill="#27ae60">
                    <font>
                        <Font name="B Yekan" size="16.0" />
                    </font>
                </Label>

                <!-- جدول نمایش داده‌ها -->
                <TableView fx:id="dataTable" prefHeight="500.0" prefWidth="900.0" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <!-- دکمه‌های عملیاتی زیر جدول -->
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>

                        <!-- دکمه مشاهده جزئیات (بخش جدید) -->
                        <Button fx:id="btnViewDetails" mnemonicParsing="false" onAction="#handleViewDetails" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="👁 جزئیات">
                            <font><Font name="B Yekan" size="14.0" /></font>
                        </Button>

                        <!-- دکمه‌های قبلی -->
                        <Button fx:id="btnApprove" mnemonicParsing="false" onAction="#handleApprove" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="✔ تایید آگهی">
                            <font><Font name="B Yekan" size="14.0" /></font>
                        </Button>

                        <Button fx:id="btnReject" mnemonicParsing="false" onAction="#handleReject" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="✖ رد آگهی">
                            <font><Font name="B Yekan" size="14.0" /></font>
                        </Button>

                        <Button fx:id="btnUnblock" mnemonicParsing="false" onAction="#handleUnblock" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="رفع مسدودی">
                            <font><Font name="B Yekan" size="14.0" /></font>
                        </Button>

                        <Button fx:id="btnBlock" mnemonicParsing="false" onAction="#handleBlock" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="مسدود کردن">
                            <font><Font name="B Yekan" size="14.0" /></font>
                        </Button>

                        <Button fx:id="btnDelete" mnemonicParsing="false" onAction="#handleDelete" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="🗑 حذف">
                            <font><Font name="B Yekan" size="14.0" /></font>
                        </Button>
                    </children>
                </HBox>

            </children>
        </VBox>
    </center>
</BorderPane>