<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.ComboBox?>

<AnchorPane prefHeight="792.0" prefWidth="1328.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.controller.CreateAdController">
   <children>
      <Label layoutX="596.0" layoutY="50.0" text="ثبت آگهی جدید">
         <font>
            <Font name="B Yekan" size="24.0" />
         </font>
      </Label>

      <Label fx:id="messageLabel" alignment="CENTER" layoutX="464.0" layoutY="100.0" prefHeight="20.0" prefWidth="400.0" textFill="RED">
         <font>
            <Font name="B Yekan" size="14.0" />
         </font>
      </Label>

      <!-- فرم اطلاعات (سمت راست) -->
      <TextField fx:id="titleField" alignment="CENTER_RIGHT" layoutX="600.0" layoutY="140.0" prefHeight="40.0" prefWidth="300.0" promptText="عنوان آگهی" />
      <TextField fx:id="priceField" alignment="CENTER_RIGHT" layoutX="600.0" layoutY="200.0" prefHeight="40.0" prefWidth="300.0" promptText="قیمت (تومان)" />
      <TextField fx:id="cityField" alignment="CENTER_RIGHT" layoutX="600.0" layoutY="260.0" prefHeight="40.0" prefWidth="300.0" promptText="شهر" />
      <ComboBox fx:id="categoryComboBox" nodeOrientation="RIGHT_TO_LEFT" layoutX="600.0" layoutY="320.0" prefHeight="40.0" prefWidth="300.0" promptText="دسته‌بندی" />
      <TextArea fx:id="descriptionField" nodeOrientation="RIGHT_TO_LEFT" layoutX="600.0" layoutY="380.0" prefHeight="120.0" prefWidth="300.0" promptText="توضیحات آگهی..." />

      <!-- بخش آپلود عکس (سمت چپ) -->
      <ImageView fx:id="imageView" layoutX="250.0" layoutY="160.0" fitHeight="200.0" fitWidth="200.0" preserveRatio="true" style="-fx-border-color: #ccc; -fx-border-width: 2;" />
      <Button layoutX="285.0" layoutY="380.0" mnemonicParsing="false" onAction="#handleChooseImage" prefHeight="35.0" prefWidth="130.0" text="انتخاب عکس">
         <font>
            <Font name="B Yekan" size="14.0" />
         </font>
      </Button>

      <Button layoutX="600.0" layoutY="550.0" mnemonicParsing="false" onAction="#handleSubmit" prefHeight="45.0" prefWidth="128.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="ثبت نهایی">
         <font>
            <Font name="B Yekan" size="18.0" />
         </font>
      </Button>

      <Button layoutX="50.0" layoutY="30.0" mnemonicParsing="false" onAction="#goBack" prefHeight="40.0" prefWidth="100.0" text="بازگشت">
         <font>
            <Font name="B Yekan" size="14.0" />
         </font>
      </Button>
   </children>
</AnchorPane>