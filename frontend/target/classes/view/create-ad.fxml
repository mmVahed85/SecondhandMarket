<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="820.0"
            prefWidth="1350.0"
            style="-fx-background-color:#f5f7fb;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.secondhand.controller.CreateAdController">

    <children>

        <VBox spacing="25"
              AnchorPane.topAnchor="30"
              AnchorPane.bottomAnchor="30"
              AnchorPane.leftAnchor="40"
              AnchorPane.rightAnchor="40">

            <children>

                <Label text="ثبت آگهی جدید">
                    <font>
                        <Font name="B Yekan" size="28"/>
                    </font>
                </Label>

                <Label fx:id="messageLabel"
                       style="-fx-font-size:14px;"/>

                <HBox spacing="30">

                    <!-- ================= تصاویر ================= -->

                    <VBox spacing="15"
                          prefWidth="420"
                          style="-fx-background-color:white;
                                 -fx-background-radius:15;
                                 -fx-border-radius:15;
                                 -fx-border-color:#dddddd;
                                 -fx-padding:20;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,.12),10,0,0,2);">

                        <children>

                            <Label text="تصاویر آگهی">
                                <font>
                                    <Font name="B Yekan" size="18"/>
                                </font>
                            </Label>

                            <FlowPane fx:id="imagesPane"
                                      prefWidth="360"
                                      prefHeight="360"
                                      hgap="10"
                                      vgap="10"
                                      prefWrapLength="340"
                                      style="-fx-background-color:#fafafa;
                                             -fx-background-radius:10;
                                             -fx-border-radius:10;
                                             -fx-border-color:#dddddd;
                                             -fx-padding:10;"/>

                            <Button text="📷 انتخاب تصاویر"
                                    onAction="#handleChooseImage"
                                    prefHeight="42"
                                    maxWidth="Infinity"
                                    style="-fx-background-color:#2196F3;
                                           -fx-text-fill:white;
                                           -fx-background-radius:8;"/>

                        </children>

                    </VBox>

                    <!-- ================= فرم ================= -->

                    <VBox spacing="15"
                          HBox.hgrow="ALWAYS"
                          style="-fx-background-color:white;
                                 -fx-background-radius:15;
                                 -fx-border-radius:15;
                                 -fx-border-color:#dddddd;
                                 -fx-padding:25;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,.12),10,0,0,2);">

                        <children>

                            <TextField fx:id="titleField"
                                       promptText="عنوان آگهی"/>

                            <TextField fx:id="priceField"
                                       promptText="قیمت (تومان)"/>

                            <TextField fx:id="cityField"
                                       promptText="شهر"/>

                            <ComboBox fx:id="categoryComboBox"
                                      promptText="دسته‌بندی"/>

                            <TextArea fx:id="descriptionField"
                                      prefHeight="180"
                                      wrapText="true"
                                      promptText="توضیحات آگهی..."/>

                        </children>

                    </VBox>

                </HBox>

                <HBox spacing="15">

                    <Button text="ثبت نهایی"
                            onAction="#handleSubmit"
                            prefWidth="170"
                            prefHeight="45"
                            style="-fx-background-color:#4CAF50;
                                   -fx-text-fill:white;
                                   -fx-background-radius:8;"/>

                    <Button text="بازگشت"
                            onAction="#goBack"
                            prefWidth="130"
                            prefHeight="45"
                            style="-fx-background-color:#eeeeee;
                                   -fx-background-radius:8;"/>

                </HBox>

            </children>

        </VBox>

    </children>

</AnchorPane>