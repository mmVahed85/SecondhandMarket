<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.ComboBox?>

<AnchorPane prefHeight="792.0" prefWidth="1328.0" nodeOrientation="RIGHT_TO_LEFT" style="-fx-background-color: #f5f6fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.controller.EditAdController">
    <children>
        <VBox alignment="CENTER" spacing="15.0" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="350.0" AnchorPane.rightAnchor="350.0" AnchorPane.topAnchor="50.0" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <children>
                <Label text="ویرایش آگهی">
                    <font><Font name="B Yekan" size="24.0" /></font>
                </Label>

                <TextField fx:id="titleField" prefHeight="40.0" promptText="عنوان آگهی">
                    <font><Font name="B Yekan" size="14.0" /></font>
                </TextField>

                <TextField fx:id="priceField" prefHeight="40.0" promptText="قیمت (تومان)">
                    <font><Font name="B Yekan" size="14.0" /></font>
                </TextField>

                <!-- فیلد متنی آزاد برای شهر -->
                <TextField fx:id="cityField" prefHeight="40.0" promptText="شهر">
                    <font><Font name="B Yekan" size="14.0" /></font>
                </TextField>

                <!-- فیلد متنی آزاد برای دسته‌بندی -->
                <ComboBox fx:id="categoryComboBox"
                        prefHeight="40.0"
                        promptText="دسته‌بندی">
                    <font>
                        <Font name="B Yekan" size="14.0"/>
                    </font>
                </ComboBox>

                <ComboBox fx:id="statusComboBox"
                        prefHeight="40.0"
                        promptText="وضعیت">
                    <font>
                        <Font name="B Yekan" size="14.0"/>
                    </font>
                </ComboBox>

                <TextArea fx:id="descriptionArea" prefHeight="120.0" promptText="توضیحات آگهی..." wrapText="true">
                    <font><Font name="B Yekan" size="14.0" /></font>
                </TextArea>

                <Label fx:id="messageLabel" textFill="#27ae60">
                    <font><Font name="B Yekan" size="14.0" /></font>
                </Label>

                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#saveChanges" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="ذخیره تغییرات">
                            <font><Font name="B Yekan" size="14.0" /></font>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#goBack" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #e0e0e0; -fx-text-fill: black;" text="بازگشت به پروفایل">
                            <font><Font name="B Yekan" size="14.0" /></font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>