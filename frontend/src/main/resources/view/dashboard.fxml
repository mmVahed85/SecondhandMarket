<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="792.0" prefWidth="1328.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.controller.DashboardController">
   <children>
      <!-- هدر بالای صفحه -->
      <Label layoutX="1136.0" layoutY="28.0" text="آگهی‌های دست دوم">
         <font>
            <Font name="B Yekan" size="24.0" />
         </font>
      </Label>
      
      <!-- دکمه خروج -->
      <Button layoutX="49.0" layoutY="28.0" mnemonicParsing="false" onAction="#handleLogout" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: #ff4d4d; -fx-text-fill: white;" text="خروج">
         <font>
            <Font name="B Yekan" size="16.0" />
         </font>
      </Button>

      <!-- دکمه ثبت آگهی جدید -->
      <Button layoutX="168.0" layoutY="28.0" mnemonicParsing="false" onAction="#goToCreateAd" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="+ ثبت آگهی جدید">
         <font>
            <Font name="B Yekan" size="16.0" />
         </font>
      </Button>

      <!-- بخش اصلی برای نمایش آگهی‌ها -->
      <ScrollPane layoutX="49.0" layoutY="95.0" prefHeight="650.0" prefWidth="1230.0" style="-fx-background-color: transparent;">
         <content>
            <!-- کانتینری که آگهی‌ها داخل آن به صورت داینامیک اضافه می‌شوند -->
            <TilePane fx:id="adsContainer" hgap="20.0" prefWidth="1200.0" style="-fx-padding: 20;" vgap="20.0" />
         </content>
      </ScrollPane>
   </children>
</AnchorPane>