<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="792.0" prefWidth="1328.0" nodeOrientation="LEFT_TO_RIGHT" style="-fx-background-color: #f5f6fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.controller.ChatListController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="30.0" left="250.0" right="250.0" top="30.0" />
            </padding>
            <children>

                <!-- Page Header -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#goBack" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: white; -fx-border-color: #2196F3; -fx-text-fill: #2196F3; -fx-border-radius: 5;" text="Back">
                            <font><Font name="Arial" size="14.0" /></font>
                        </Button>
                        <Label text="My Messages">
                            <font><Font name="Arial" size="24.0" /></font>
                        </Label>
                    </children>
                </HBox>

                <!-- Chat List Section -->
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="chatListContainer" spacing="10.0">
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>

            </children>
        </VBox>
    </children>
</AnchorPane>