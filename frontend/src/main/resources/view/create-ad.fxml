<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="820.0"
            prefWidth="1350.0"
            nodeOrientation="LEFT_TO_RIGHT"
            style="-fx-background-color:#f5f7fb;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.secondhand.controller.CreateAdController">

    <children>

        <VBox spacing="25"
              AnchorPane.topAnchor="30"
              AnchorPane.bottomAnchor="30"
              AnchorPane.leftAnchor="40"
              AnchorPane.rightAnchor="40">

            <children>

                <Label text="Create New Ad">
                    <font>
                        <Font name="Arial" size="28"/>
                    </font>
                </Label>

                <Label fx:id="messageLabel"
                       style="-fx-font-size:14px;"/>

                <HBox spacing="30">

                    <!-- ================= Images Section ================= -->

                    <VBox spacing="15"
                          prefWidth="420"
                          style="-fx-background-color:white; -fx-background-radius:15; -fx-border-radius:15; -fx-border-color:#dddddd; -fx-padding:20; -fx-effect:dropshadow(gaussian,rgba(0,0,0,.12),10,0,0,2);">

                        <children>

                            <Label text="Ad Images">
                                <font>
                                    <Font name="Arial" size="18"/>
                                </font>
                            </Label>

                            <FlowPane fx:id="imagesPane"
                                      prefWidth="360"
                                      prefHeight="360"
                                      hgap="10"
                                      vgap="10"
                                      prefWrapLength="340"
                                      style="-fx-background-color:#fafafa; -fx-background-radius:10; -fx-border-radius:10; -fx-border-color:#dddddd; -fx-padding:10;"/>

                            <Button text="📷 Choose Images"
                                    onAction="#handleChooseImage"
                                    prefHeight="42"
                                    maxWidth="Infinity"
                                    style="-fx-background-color:#2196F3; -fx-text-fill:white; -fx-background-radius:8;">
                                <font>
                                    <Font name="Arial" size="14"/>
                                </font>
                            </Button>

                        </children>

                    </VBox>

                    <!-- ================= Form Section ================= -->

                    <VBox spacing="15"
                          HBox.hgrow="ALWAYS"
                          style="-fx-background-color:white; -fx-background-radius:15; -fx-border-radius:15; -fx-border-color:#dddddd; -fx-padding:25; -fx-effect:dropshadow(gaussian,rgba(0,0,0,.12),10,0,0,2);">

                        <children>

                            <TextField fx:id="titleField" promptText="Ad Title">
                                <font><Font name="Arial" size="14"/></font>
                            </TextField>

                            <TextField fx:id="priceField" promptText="Price">
                                <font><Font name="Arial" size="14"/></font>
                            </TextField>

                            <TextField fx:id="cityField" promptText="City">
                                <font><Font name="Arial" size="14"/></font>
                            </TextField>

                            <ComboBox fx:id="categoryComboBox" promptText="Category" prefHeight="40" prefWidth="250" />

                            <TextArea fx:id="descriptionField"
                                      prefHeight="180"
                                      wrapText="true"
                                      promptText="Ad Description...">
                                <font><Font name="Arial" size="14"/></font>
                            </TextArea>

                        </children>

                    </VBox>

                </HBox>

                <HBox spacing="15">

                    <Button text="Submit"
                            onAction="#handleSubmit"
                            prefWidth="170"
                            prefHeight="45"
                            style="-fx-background-color:#4CAF50; -fx-text-fill:white; -fx-background-radius:8;">
                        <font><Font name="Arial" size="14"/></font>
                    </Button>

                    <Button text="Back"
                            onAction="#goBack"
                            prefWidth="130"
                            prefHeight="45"
                            style="-fx-background-color:#eeeeee; -fx-background-radius:8;">
                        <font><Font name="Arial" size="14"/></font>
                    </Button>

                </HBox>

            </children>

        </VBox>

    </children>

</AnchorPane>