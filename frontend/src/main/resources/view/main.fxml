<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="792.0" prefWidth="1328.0" spacing="25" nodeOrientation="LEFT_TO_RIGHT" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.controller.MainController">

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Welcome to Secondhand Market">
        <font>
            <Font name="Arial" size="19.0" />
        </font>
    </Label>

    <Button onAction="#goToLogin" prefHeight="45.0" prefWidth="200.0" text="Login to Account">
        <font>
            <Font name="Arial" size="16.0" />
        </font>
    </Button>

    <Button onAction="#goToRegister" prefHeight="45.0" prefWidth="200.0" text="Register New User">
        <font>
            <Font name="Arial" size="16.0" />
        </font>
    </Button>

</VBox>